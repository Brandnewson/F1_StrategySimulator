{
    "debugMode": false,
    "agent_review_mode": true,
    "competitors": [
        {
            "name": "DQN Agent",
            "agent": "dqn",
            "colour": "#022050"
        },
        {
            "name": "Base Agent",
            "agent": "base",
            "colour": "#FFA500"
        }
    ],
    "simulator": {
        "runs": 20,
        "run_name": "dqn agent vs base agent",
        "visualise_from_run_name": "",
